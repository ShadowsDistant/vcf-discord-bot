DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
# Optional: deploy commands to a single guild for instant updates (recommended while developing)
GUILD_ID=
# Optional: comma-separated command names to require during deploy validation
# Example: REQUIRED_BAKE_COMMANDS=bake,bakery,marketplace,bakeadmin
REQUIRED_BAKE_COMMANDS=

# Optional: Discord user ID allowed to use developer commands (/setstatus, /servers, /announce)
# Defaults to the bot owner ID if not set
DEV_USER_ID=

# Optional: NVIDIA Build API key used by /ai command
NVIDIA_API_KEY=
