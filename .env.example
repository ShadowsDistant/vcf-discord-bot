DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Optional: set this to deploy commands to a single guild (instant, for testing)
# Leave blank to deploy globally (takes up to 1 hour to propagate)
GUILD_ID=

# Optional: when deploying to a guild, remove global commands with matching names
# to prevent duplicate slash command entries in Discord.
CLEAR_GLOBAL_DUPLICATES=false

# Optional: Discord user ID allowed to use developer commands (/setstatus, /servers, /announce)
# Defaults to the bot owner ID if not set
DEV_USER_ID=
